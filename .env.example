# === Aplicación ===
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=cambiar-en-produccion

# === MongoDB (driver nativo) ===
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=registro_municipal

# === Email / magic link (MailHog en dev) ===
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@registro.local
MAGIC_LINK_TTL_MIN=15

# === Almacenamiento de adjuntos ===
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=10
# TODO produccion: configurar object storage (S3-compatible) en lugar de disco local
